# ─────────────────────────────────────────────────────────────────────────────
# DocFinder — variables d'environnement
# Copier ce fichier en .env (gitignored) et renseigner les vraies valeurs.
# ─────────────────────────────────────────────────────────────────────────────

# Token Cloudflare Tunnel #1 (Mac → docfinder.jinkohub.digital).
# Zero Trust → Networks → Tunnels → <ton tunnel> → token
CLOUDFLARE_TUNNEL_TOKEN=

# URL publique stable du tunnel #1 (configurée côté dashboard Cloudflare
# → Public Hostname → hostname pointant vers http://localhost:8000).
# Exemple : https://docfinder.mondomaine.com
DOCFINDER_PUBLIC_URL=

# Racines autorisées pour /files/list et /files/raw (server/files_api.py).
# Plusieurs chemins séparés par ':'.
DOCFINDER_ROOTS=/Users/julien/Documents

# Cloudflare Access service token (Zero Trust → Access → Service Auth).
# Utilisé des deux côtés : Colab → Mac (/files/*, /admin/*) ET Mac → Colab (/encode).
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Secret partagé Mac ↔ Colab : header X-Auth-Token sur POST /encode.
# Générer : python3 -c "import secrets; print(secrets.token_urlsafe(32))"
COLAB_QUERY_TOKEN=

# URL du tunnel Cloudflare #2 (Colab) exposant /encode.
COLAB_ENCODE_URL=https://encode.jinkohub.digital
