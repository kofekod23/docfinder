# ─────────────────────────────────────────────────────────────────────────────
# DocFinder — variables d'environnement
# Copier ce fichier en .env (gitignored) et renseigner les vraies valeurs.
# ─────────────────────────────────────────────────────────────────────────────

# Token Cloudflare Tunnel (Zero Trust → Networks → Tunnels → ton tunnel → token)
# /!\ Ne JAMAIS commiter cette valeur. Le .env est gitignored par défaut.
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoiZjc0ZjFmMThkMGZiNjI3NGVlY2MzMjc2NDBiOWIxNDUiLCJ0IjoiMjRhMjExMDItYzk2Yi00MjcwLTg0ZDgtMzJiZWEyNDY2NTBlIiwicyI6IlpHRXpPREl6WTJJdFltVXpOQzAwTjJOaExXRTFPV0l0TmpObFpUZGlPRFZsWWpNeCJ9

# URL publique stable du tunnel (configurée côté dashboard Cloudflare
# → Public Hostname → hostname pointant vers http://localhost:8000)
# Exemple : https://docfinder.mondomaine.com
DOCFINDER_PUBLIC_URL=

# (Optionnel) Chemin racine par défaut pour l'indexation
# ICLOUD_DEFAULT=/Users/julien/Library/Mobile Documents/com~apple~CloudDocs

# Feature flag: route /search to v2 engine (BGE-M3 with ColBERT reranking)
USE_V2=false



CF-Access-Client-Id: b210659ae473de5ef9f611bdb6626da3.access
CF-Access-Client-Secret: ce2212c6478adae87faeb9e250ddb45281a99e5d4854aa34b6ef4f643fafa61d


# Cloudflare Tunnel nécessite des headers spéciaux.
_HEADERS: dict = {"CF-Access-Client-Id": "b210659ae473de5ef9f611bdb6626da3.access",
                  "CF-Access-Client-Secret": "ce2212c6478adae87faeb9e250ddb45281a99e5d4854aa34b6ef4f643fafa61d",}

# URL Cloudflare Tunnel du Mac (port 8000)
# Sur le Mac : cloudflared tunnel --url http://localhost:8000
# → copiez l'URL HTTPS affichée (ex. https://xxx.trycloudflare.com)
# L'URL est stable entre les restarts — pas besoin de la changer régulièrement.
DOCFINDER_URL = "https://docfinder.jinkohub.digital"